# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Places API
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Kommo CRM API
KOMMO_BASE_URL=https://your-account.kommo.com/api/v4
KOMMO_ACCESS_TOKEN=your-kommo-access-token
KOMMO_REFRESH_TOKEN=your-kommo-refresh-token

# Worker Configuration
WORKER_POLL_INTERVAL_MS=10000
WORKER_JOBS_BATCH_SIZE=1
WORKER_LOG_LEVEL=info

# Rate Limiting
GOOGLE_PLACES_DETAIL_DELAY_MS=200
GOOGLE_PLACES_PAGE_DELAY_MS=2000

# Scoring
SCORE_CUTOFF=60
